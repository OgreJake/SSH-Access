# Copy to .env and source it (e.g. `set -a; . ./.env; set +a`) before `make run`.

# Environment: dev | prod
SSHBROKER_ENV=dev

# Log level: debug | info | warn | error
SSHBROKER_LOG_LEVEL=info

# HTTP health/admin listener
SSHBROKER_HEALTH_ADDR=:8080

# PostgreSQL DSN (matches docker-compose.yml)
SSHBROKER_DATABASE_URL=postgres://broker:broker@localhost:5432/broker?sslmode=disable

# CA signer backend: file (dev) or kms (production, ADR-006)
SSHBROKER_CA_BACKEND=file

# Dev CA key (generate with `make gen-ca`). Used when CA_BACKEND=file.
SSHBROKER_CA_KEY_PATH=dev/ca_key
# SSHBROKER_CA_KEY_PASSPHRASE=

# KMS CA settings (used when CA_BACKEND=kms). The broker authenticates to KMS
# with its EC2 instance role; no static credentials here.
# SSHBROKER_KMS_KEY_ID=alias/sshbroker-ca
# SSHBROKER_AWS_REGION=us-east-1

# Dev secret store. Prod replaces this with KMS envelope encryption.
SSHBROKER_SECRET_STORE_DIR=dev/secrets
# Base64-encoded 32-byte key. Generate with `make gen-secret-key`.
SSHBROKER_SECRET_STORE_KEY=

# Graceful shutdown timeout
SSHBROKER_SHUTDOWN_TIMEOUT=10s

# --- Certificate issuance policy (ADR-007) ---
# Hard cap on every issued certificate's lifetime
SSHBROKER_CERT_MAX_TTL=5m
# Tolerance subtracted from ValidAfter to absorb clock skew between broker/targets
SSHBROKER_CERT_CLOCK_SKEW=1m
# If set, issued certs are pinned to this source address/CIDR (the broker's
# egress address). Leave empty in local dev. Example: 10.0.0.10/32
SSHBROKER_BROKER_SOURCE_ADDR=

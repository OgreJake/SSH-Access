# Copy to .env and source it (e.g. `set -a; . ./.env; set +a`) before `make run`.

# Environment: dev | prod
SSHBROKER_ENV=dev

# Log level: debug | info | warn | error
SSHBROKER_LOG_LEVEL=info

# HTTP health/admin listener
SSHBROKER_HEALTH_ADDR=:8080

# PostgreSQL DSN (matches docker-compose.yml)
SSHBROKER_DATABASE_URL=postgres://broker:broker@localhost:5432/broker?sslmode=disable

# CA signer backend: file (dev) or kms (production, ADR-006)
SSHBROKER_CA_BACKEND=file

# Dev CA key (generate with `make gen-ca`). Used when CA_BACKEND=file.
SSHBROKER_CA_KEY_PATH=dev/ca_key
# SSHBROKER_CA_KEY_PASSPHRASE=

# KMS CA settings (used when CA_BACKEND=kms). The broker authenticates to KMS
# with its EC2 instance role; no static credentials here.
# SSHBROKER_KMS_KEY_ID=alias/sshbroker-ca
# SSHBROKER_AWS_REGION=us-east-1

# Dev secret store. Prod replaces this with KMS envelope encryption.
SSHBROKER_SECRET_STORE_DIR=dev/secrets
# Base64-encoded 32-byte key. Generate with `make gen-secret-key`.
SSHBROKER_SECRET_STORE_KEY=

# Graceful shutdown timeout
SSHBROKER_SHUTDOWN_TIMEOUT=10s

# --- SSH front door (Phase 2) ---
# Address the broker's SSH server listens on
SSHBROKER_SSH_LISTEN_ADDR=:2222
# Broker host key (generate with `make gen-host-key`)
SSHBROKER_SSH_HOST_KEY_PATH=dev/host_key
# Authentication backend: "file" (dev authorized_users below) or "db"
# (PostgreSQL user/service-account keys). DB-backed refuses disabled accounts.
SSHBROKER_AUTH_BACKEND=file
# Dev file of registered users in authorized_keys format; the key comment is
# taken as the username. Used when AUTH_BACKEND=file.
SSHBROKER_AUTHORIZED_USERS_PATH=dev/authorized_users
# Authorization backend: "file" (dev targets.json below) or "db" (PostgreSQL
# servers/groups/grants RBAC). Multiple matching grants compose: union of
# capabilities, longest permitted TTL.
SSHBROKER_AUTHZ_BACKEND=file
# Dev JSON policy of targets + grants (see targets.example.json). Used when
# AUTHZ_BACKEND=file.
SSHBROKER_TARGETS_PATH=dev/targets.json

# --- Certificate issuance policy (ADR-007) ---
# Hard cap on every issued certificate's lifetime
SSHBROKER_CERT_MAX_TTL=5m
# Tolerance subtracted from ValidAfter to absorb clock skew between broker/targets
SSHBROKER_CERT_CLOCK_SKEW=1m
# If set, issued certs are pinned to this source address/CIDR (the broker's
# egress address). Leave empty in local dev. Example: 10.0.0.10/32
SSHBROKER_BROKER_SOURCE_ADDR=

# ---- Management API (cmd/api, ADR-005) ----
# The API runs as a SEPARATE process from the SSH broker. It needs only the
# database below plus these. Put it behind TLS-terminating ingress in prod.
SSHBROKER_API_ADDR=:8081
# Static bearer token protecting the API. Generate a strong random value; the
# API refuses to start if this is empty. Browser/session auth (with MFA) is a
# later slice.
SSHBROKER_API_TOKEN=

# ADR-016: how often the broker checks live sessions for termination (disabled
# account or explicit kill). Default 10s.
SSHBROKER_REVOCATION_INTERVAL=10s

# ADR-011: directory for full session recordings (.cast files). When unset,
# full recording is disabled even if a grant requests it. Set the same path on
# the API process to enable recording downloads.
SSHBROKER_RECORDING_DIR=/var/lib/sshbroker/recordings
